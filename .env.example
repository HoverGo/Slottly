# Для локального запуска без Docker скопируйте в .env и укажите localhost
# В Docker переменные задаются в docker-compose.yml

SECRET_KEY=change-me-to-a-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=60
DEBUG=false
ENVIRONMENT=development
PAYMENT_PROVIDER=mock
PAYMENT_RETURN_URL=http://localhost:8000/cabinet/payments/success

# Webhook: секрет в заголовке X-Webhook-Secret (обязателен в production)
# PAYMENT_WEBHOOK_SECRET=your-random-webhook-secret

# ЮKassa (production)
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=

# Docker (по умолчанию в compose)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/commerce_db

# CORS — список origin через запятую (пусто = CORS middleware не подключается)
# CORS_ORIGINS=http://localhost:3000

# Trusted Host — список хостов через запятую (за reverse proxy)
# TRUSTED_HOSTS=localhost,127.0.0.1,api.example.com
# TRUST_PROXY_HEADERS=false

# Rate limit и brute-force (по умолчанию включены)
# RATE_LIMIT_ENABLED=true
# BRUTE_FORCE_ENABLED=true
# LOGIN_MAX_ATTEMPTS=5
# LOGIN_LOCKOUT_MINUTES=15

# Redis для rate limit / brute-force между воркерами (пусто = in-memory, только для dev/тестов)
# REDIS_URL=redis://redis:6379/0

# Audit log действий на сервере (по умолчанию включён)
# AUDIT_ENABLED=true

# Роли платформы (email через запятую, права выдаются при старте API)
# PLATFORM_ADMIN_EMAILS=admin@example.com
# PLATFORM_SUPPORT_EMAILS=support@example.com

# Ссылка для активации приглашения сотрудника (фронтенд)
# INVITE_BASE_URL=http://localhost:3000/invite
# INVITE_TOKEN_EXPIRE_DAYS=7

# Локально без Docker
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/commerce_db

# Production (ENVIRONMENT=production) — обязательно:
# SECRET_KEY — случайная строка >= 32 символов
# DATABASE_URL — не postgres/postgres
# PAYMENT_PROVIDER=yookassa
# PAYMENT_WEBHOOK_SECRET — секрет webhook
# DEBUG=false
